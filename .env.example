# ── XSOAR Connection ──────────────────────────────────────────────────────────
XSOAR_URL=https://your-xsoar-server.company.com
XSOAR_API_KEY=your-xsoar-api-key-here
XSOAR_VERIFY_SSL=true   # set to false for self-signed certificates

# ── AI Provider ───────────────────────────────────────────────────────────────
# Set AI_PROVIDER to one of the values below (or select interactively at startup)
# openai | azure | claude | gemini | groq | mistral | together |
# deepseek | perplexity | xai | cohere | ollama | lmstudio
AI_PROVIDER=openai

# AI_API_KEY   — API key for the selected provider
# AI_MODEL     — Model name (optional, a default is provided for each provider)
# AI_BASE_URL  — Only needed for: azure, ollama, lmstudio
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o
# AI_BASE_URL=

# ── Provider-specific keys (alternative to AI_API_KEY) ───────────────────────
# You can also set provider-specific variables instead of AI_API_KEY:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# TOGETHER_API_KEY=...
# DEEPSEEK_API_KEY=sk-...
# PERPLEXITY_API_KEY=pplx-...
# XAI_API_KEY=xai-...
# COHERE_API_KEY=...

# ── Local LLM URLs (only if using ollama or lmstudio) ────────────────────────
# OLLAMA_URL=http://localhost:11434
# LMSTUDIO_URL=http://localhost:1234
