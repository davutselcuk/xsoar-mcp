# ─── XSOAR Bağlantısı ────────────────────────────────────────────────────────
# XSOAR sunucusunun tam adresi
XSOAR_URL=https://your-xsoar-server.company.com

# XSOAR API Key (Settings > API Keys > Generate New Key)
XSOAR_API_KEY=your-xsoar-api-key-here

# Self-signed sertifika varsa false yap
XSOAR_VERIFY_SSL=true

# ─── Local AI Bağlantısı ─────────────────────────────────────────────────────
# OpenAI uyumlu API base URL (sonunda /v1 olabilir, AI'ınıza göre değişir)
AI_BASE_URL=http://your-local-ai-server:8080/v1

# Local AI API anahtarı (gerekiyorsa)
AI_API_KEY=your-ai-api-key-here

# Kullanılacak model adı (AI'ınızın sunduğu model)
AI_MODEL=your-model-name
